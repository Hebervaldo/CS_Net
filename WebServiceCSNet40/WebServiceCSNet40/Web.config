<?xml version="1.0"?>
<!--
  For more information on how to configure your ASP.NET application, please visit
  http://go.microsoft.com/fwlink/?LinkId=169433
  -->
<configuration>
  <system.web>
    <httpRuntime
		executionTimeout="999999"
		maxRequestLength="2097151"
		useFullyQualifiedRedirectUrl="false"
		minFreeThreads="8"
		minLocalRequestFreeThreads="4"
		appRequestQueueLimit="100"
		enableVersionHeader="true"
		/>

    <!-- Web.Config Configuration File -->

    <customErrors mode="Off"/>

    <compilation debug="true" targetFramework="4.0">
      <assemblies>
        <add assembly="System.Design, Version=4.0.0.0, Culture=neutral, PublicKeyToken=B03F5F7F11D50A3A"/>
        <add assembly="System.Web.Extensions.Design, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35"/>
        <add assembly="System.Windows.Forms, Version=4.0.0.0, Culture=neutral, PublicKeyToken=B77A5C561934E089"/>
      </assemblies>
    </compilation>

    <!--<authentication mode="Forms">
			<forms name="login" loginUrl="login.aspx" />
		</authentication>-->

    <authentication mode="Forms">
      <forms name="login" loginUrl="login.aspx">
        <credentials passwordFormat="Clear">
          <user name="Administrador" password="12345678"/>
          <user name="Usuario" password="123457678"/>
          <user name="ftpUsuario" password="723564"/>
        </credentials>
      </forms>
    </authentication>

    <authorization>
      <allow roles="Administrador" />
      <allow roles="Usuario" />
      <allow roles="ftpUsuario" />
      <deny users="*" />
    </authorization>
  </system.web>

  <!-- Definindo a restrição de acesso a pasta Administrador-->
  <location path="Administrador">
    <system.web>
      <authorization>
        <deny users="?"/>
        <allow roles="Administrador" />
        <allow roles="ftpUsuario" />
      </authorization>
    </system.web>
  </location>

  <!-- Definindo a restrição de acesso a pasta Usuário-->
  <location path="Usuario">
    <system.web>
      <authorization>
        <deny users="?"/>
        <allow roles="Administrador" />
        <allow roles="Usuario" />
        <allow roles="ftpUsuario" />
      </authorization>
    </system.web>
  </location>

  <!-- Definindo a restrição de acesso a pasta Todos-->
  <location path="Todos">
    <system.web>
      <authorization>
        <allow users="?"/>
      </authorization>
    </system.web>
  </location>

  <!-- Definindo a restrição de acesso a pasta Armazenamento-->
  <location path="Armazenamento">
    <system.web>
      <authorization>
        <deny users="?"/>
        <allow users="Administrador"/>
        <allow users="Usuario"/>
        <allow roles="ftpUsuario" />
      </authorization>
    </system.web>
  </location>

  <!-- Definindo a restrição de acesso a pasta Bibliotecas-->
  <location path="Bibliotecas">
    <system.web>
      <authorization>
        <deny users="?"/>
        <allow users="Administrador"/>
        <allow users="Usuario"/>
        <allow roles="ftpUsuario" />
      </authorization>
    </system.web>
  </location>

  <!-- Definindo a restrição de acesso a pasta Imagem-->
  <location path="Imagem">
    <system.web>
      <authorization>
        <deny users="?"/>
        <allow users="Administrador"/>
        <allow users="Usuario"/>
        <allow roles="ftpUsuario" />
      </authorization>
    </system.web>
  </location>
</configuration>